# Makefile — copy to your repo root. The four gates plus common tasks.
# Requires Go 1.26+. golangci-lint via the go.mod `tool` directive.

.DEFAULT_GOAL := check
.PHONY: check fmt fmt-check vet lint build test test-race cover tidy clean ci

## check: format-check + vet + build + race tests (the local gate)
check: fmt-check vet build test-race

## fmt: format code and group imports
fmt:
	gofmt -w .
	go run golang.org/x/tools/cmd/goimports@latest -w .

## fmt-check: fail if anything is unformatted
fmt-check:
	@test -z "$$(gofmt -l .)" || { echo "unformatted files:"; gofmt -l .; exit 1; }

## vet: built-in static analysis
vet:
	go vet ./...

## lint: golangci-lint v2 (tracked via the tool directive)
lint:
	go tool golangci-lint run ./...

## build: compile everything
build:
	go build ./...

## test: run tests
test:
	go test ./...

## test-race: run tests with the race detector
test-race:
	go test -race ./...

## cover: coverage report -> cover.html
cover:
	go test -coverprofile=cover.out ./...
	go tool cover -html=cover.out -o cover.html

## tidy: sync go.mod / go.sum
tidy:
	go mod tidy

## clean: remove build/coverage artefacts
clean:
	rm -f cover.out cover.html
	go clean

## ci: the full gate for CI (adds lint + coverage)
ci: fmt-check vet lint build
	go test -race -coverprofile=cover.out ./...
