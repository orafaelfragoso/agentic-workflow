{
  "$schema": "https://json.schemastore.org/claude-code-plugin-manifest.json",
  "name": "columbus",
  "displayName": "Columbus Workflow",
  "version": "0.2.0",
  "description": "Columbus workflow with a fast indexed memory system, reusable skills, agents, and hooks.",
  "author": {
    "name": "Rafael Fragoso",
    "url": "https://github.com/orafaelfragoso"
  },
  "license": "MIT",
  "keywords": [
    "columbus",
    "go",
    "typescript",
    "commit",
    "triage",
    "agents",
    "skills",
    "hooks",
    "claude-code"
  ],
  "skills": "./plugins/columbus-workflow/skills/",
  "agents": [
    "./plugins/columbus-workflow/agents/navigator.md",
    "./plugins/columbus-workflow/agents/sprint-planner.md",
    "./plugins/columbus-workflow/agents/delivery-engineer.md",
    "./plugins/columbus-workflow/agents/test-engineer.md",
    "./plugins/columbus-workflow/agents/quality-reviewer.md",
    "./plugins/columbus-workflow/agents/security-analyst.md",
    "./plugins/columbus-workflow/agents/architecture-reviewer.md",
    "./plugins/columbus-workflow/agents/release-coordinator.md"
  ],
  "outputStyles": [
    "./plugins/columbus-workflow/output-styles/caveman.md"
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/plugins/columbus-workflow/scripts/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}\"/plugins/columbus-workflow/scripts/prompt.sh"
          }
        ]
      }
    ]
  },
  "defaultEnabled": true
}
